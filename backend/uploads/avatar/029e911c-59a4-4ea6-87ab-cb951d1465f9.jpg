server:
  port: 8081

spring:
  datasource:
    url: jdbc:mysql://192.168.159.128:3306/generator_rental?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf-8&allowPublicKeyRetrieval=true
    username: root
    password: 123
    driver-class-name: com.mysql.cj.jdbc.Driver

  data:
    redis:
      database: 0
      password: 2107450225
      timeout: 3000ms
      connect-timeout: 3000ms
      cluster:
        nodes:
          - 192.168.159.128:7000
          - 192.168.159.128:7001
          - 192.168.159.128:7002
          - 192.168.159.128:7003
          - 192.168.159.128:7004
          - 192.168.159.128:7005
        max-redirects: 3
      lettuce:
        cluster:
          refresh:
            adaptive: true
            period: 3000ms
        pool:
          max-active: 8
          max-idle: 8
          min-idle: 2
          max-wait: 1000ms

mybatis-plus:
  mapper-locations: classpath*:/mapper/**/*.xml
  type-aliases-package: com.generator.rental.entity
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

logging:
  level:
    com.generator.rental.mapper: DEBUG
